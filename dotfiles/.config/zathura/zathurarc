set selection-clipboard clipboard
set adjust-open width
set window-title-basename true
set statusbar-basename true
set guioptions ""
set scroll-step 80
set zoom-step 10
set scroll-wrap true
set continuous-hist-save true
set database sqlite

set recolor true
set recolor-keephue true
set recolor-lightcolor "#1e1e2e"
set recolor-darkcolor  "#cdd6f4"

set default-bg          "#1e1e2e"
set default-fg          "#cdd6f4"
set statusbar-bg        "#181825"
set statusbar-fg        "#cdd6f4"
set inputbar-bg         "#181825"
set inputbar-fg         "#cdd6f4"
set notification-bg     "#1e1e2e"
set notification-fg     "#a6e3a1"
set notification-error-bg "#1e1e2e"
set notification-error-fg "#f38ba8"
set notification-warning-bg "#1e1e2e"
set notification-warning-fg "#f9e2af"
set highlight-color           "#f9e2af"
set highlight-active-color    "#fab387"
set completion-bg       "#181825"
set completion-fg       "#cdd6f4"
set completion-highlight-bg "#313244"
set completion-highlight-fg "#cdd6f4"
set index-bg            "#1e1e2e"
set index-fg            "#cdd6f4"
set index-active-bg     "#313244"
set index-active-fg     "#cdd6f4"

map <C-i> recolor
map r reload
map R rotate
map u scroll half-up
map d scroll half-down
map D toggle_page_mode
map <C-d> nohlsearch
map p print
map K zoom in
map J zoom out
set synctex true
set synctex-editor-command "nvim --headless -es --cmd \"VimtexInverseSearch %{line} '%{input}'\""

